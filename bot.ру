import asyncio
import io
import os
from dotenv import load_dotenv
from aiogram import Bot, Dispatcher, types
from aiogram.filters import Command
from aiogram.types import ReplyKeyboardMarkup, KeyboardButton
from openai import OpenAI

load_dotenv()

TELEGRAM_TOKEN = os.getenv("TELEGRAM_TOKEN")
XAI_API_KEY = os.getenv("XAI_API_KEY")
OPENAI_API_KEY = os.getenv("OPENAI_API_KEY")

bot = Bot(token=TELEGRAM_TOKEN)
dp = Dispatcher()

# Клиенты API (актуально на 2026)
grok_client = OpenAI(
    api_key=XAI_API_KEY,
    base_url="https://api.x.ai/v1"
)

whisper_client = OpenAI(api_key=OPENAI_API_KEY)

users = {}

SYSTEM_PROMPT = """
Ты — лучший в мире терпеливый учитель арабского языка (Modern Standard Arabic) для русскоязычных полных новичков.
Отвечай всегда на русском языке, но вставляй арабский текст, транслитерацию и перевод.
Используй харакаты при первом знакомстве.
Будь очень добрым, мотивирующим и подробным.
Если пользователь отправил голосовое — оцени произношение, укажи ошибки и как исправить.
"""

main_keyboard = ReplyKeyboardMarkup(
    keyboard=[
        [KeyboardButton(text="📖 Урок"), KeyboardButton(text="🔤 Словарь")],
        [KeyboardButton(text="📏 Грамматика"), KeyboardButton(text="🗣 Практика речи")],
        [KeyboardButton(text="🧪 Тест"), KeyboardButton(text="ℹ️ Помощь")]
    ],
    resize_keyboard=True
)

@dp.message(Command("start"))
async def start(message: types.Message):
    user_id = message.from_user.id
    users[user_id] = {"history": [], "state": "free"}
    await message.answer(
        "👋 Привет! Я твой личный репетитор по арабскому с нуля.\n\n"
        "Алфавит, произношение, слова, грамматика и проверка речи — всё здесь!\n"
        "Пиши или отправляй голосовые.",
        reply_markup=main_keyboard
    )

@dp.message()
async def handle_message(message: types.Message):
    user_id = message.from_user.id
    if user_id not in users:
        users[user_id] = {"history": [], "state": "free"}

    user_data = users[user_id]

    if message.voice:
        await message.answer("🎤 Слушаю твой арабский...")
        file = await bot.get_file(message.voice.file_id)
        file_bytes = await bot.download_file(file.file_path)
        audio_bytes = io.BytesIO(file_bytes.read())
        audio_bytes.name = "voice.ogg"

        transcription = whisper_client.audio.transcriptions.create(
            model="whisper-1",
            file=audio_bytes,
            language="ar"
        ).text

        user_text = f"[ГОЛОСОВОЕ] Пользователь сказал: {transcription}"
        await message.answer(f"📝 Я услышал: {transcription}\nОцениваю произношение...")
    else:
        user_text = message.text

    user_data["history"].append({"role": "user", "content": user_text})
    if len(user_data["history"]) > 20:
        user_data["history"] = user_data["history"][-20:]

    messages = [{"role": "system", "content": SYSTEM_PROMPT}] + user_data["history"]

    try:
        completion = grok_client.chat.completions.create(
            model="grok-4.20-0309-reasoning",   # актуальная модель 2026
            messages=messages
        )
        response_text = completion.choices[0].message.content
    except Exception as e:
        response_text = f"Ошибка: {str(e)}\n\nПроверь API-ключи или напиши мне."

    await message.answer(response_text, parse_mode="Markdown")
    user_data["history"].append({"role": "assistant", "content": response_text})

@dp.message(Command("test"))
async def test(message: types.Message):
    await message.answer("🧪 Мини-тест готов! Пиши или говори голосом.", reply_markup=main_keyboard)

async def main():
    print("🚀 Бот запущен в облаке!")
    await dp.start_polling(bot)

if name == "__main__":
    asyncio.run(main())
